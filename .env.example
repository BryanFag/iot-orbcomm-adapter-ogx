# ============================================
# CONFIGURAÇÕES DO SERVIDOR
# ============================================
PORT=3000
HOST=0.0.0.0

# ============================================
# ORBCOMM OGWS API
# ============================================
# Ambiente de teste: https://ogws.swlab.ca/api/v1.0
# Produção: Consulte a documentação ORBCOMM

OGWS_BASE_URL=https://ogws.swlab.ca/api/v1.0
OGWS_ACCESS_ID=seu_access_id_aqui
OGWS_PASSWORD=sua_senha_aqui

# ============================================
# POLLING
# ============================================
# Intervalo em segundos entre cada busca de mensagens
POLLING_INTERVAL_SECONDS=60

# Kafka
KAFKA=localhost:9092
KAFKA_TOPIC=orbcomm-messages
KAFKA_ENABLED=true
